# .env.example

# Environment variables for QCV

# API Key for Gemini
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Database URL for NeonDB
VITE_NEONDB_URL=your_neondb_url_here

# Base URL for the API
VITE_API_BASE_URL=your_api_base_url_here

# Documentation:
# 
# VITE_GEMINI_API_KEY: This key is required to access the Gemini API. Replace 'your_gemini_api_key_here' with your actual API key.
# VITE_NEONDB_URL: Replace 'your_neondb_url_here' with your NeonDB URL. Make sure it follows the format of your database connection string.
# VITE_API_BASE_URL: Set this to your base API URL, such as 'https://api.yourdomain.com/'.